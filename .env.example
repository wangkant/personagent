# ========== HTTP service ==========
HOST=0.0.0.0
PORT=8080

# ========== NapCat / OneBot HTTP API ==========
NAPCAT_API=http://127.0.0.1:3000
# Group IDs to listen on (comma-separated)
QQ_GROUPS=

# ========== Agent — primary model (OpenAI-compatible chat completions) ==========
# Any OpenAI-compatible endpoint works: DeepSeek / Zhipu GLM / Moonshot / Together / OpenAI etc.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# ========== Web search (optional) ==========
# The agent auto-looks-up unfamiliar facts: the primary model decides the query
# via /v1 function-calling, then a backend fetches results. With a Tavily key it
# uses Tavily (keyed, more reliable); leave blank to fall back to no-key
# DuckDuckGo (requires the `ddgs` package from requirements.txt).
TAVILY_API_KEY=

# ========== Anthropic-compatible endpoint (used by the private-message path) ==========
# Leave blank to route private chats through the primary endpoint as well.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_PRIVATE_MODEL=

# ========== Bot identity ==========
BOT_QQ=
BOT_NAME=
AGENT_ENABLE=true
AGENT_TRIGGER_COUNT=30
AGENT_CONTEXT_LEN=120
AGENT_FOLLOWUP_WINDOW=120
AGENT_MEMORY_FILE=memory.json
AGENT_MEMORY_MAX=50

# Persona: copy persona.example.txt to persona.txt and edit it.
# PERSONA_FILE=persona.txt

# ========== Rate-based fallback (downgrade to a cheaper model when busy) ==========
FALLBACK_MODEL=
RATE_WINDOW=120
RATE_THRESHOLD=30
FALLBACK_DURATION=180

# ========== Self-eval (async 1-5 scoring of each reply -> eval.jsonl) ==========
# Tip: prefer a model from a DIFFERENT vendor than your main chat model.
# Same-family self-eval ("grading my own homework") tends to be blind to
# the failure modes the main model itself exhibits (AI-flavored phrasing,
# etc.). If the model name contains "moonshot" or "kimi", the agent will
# route this call through GLM_BASE_URL / GLM_API_KEY (which are also used
# by the vision path); otherwise it falls back to the main base_url.
EVAL_ENABLE=true
EVAL_MODEL=
EVAL_FILE=eval.jsonl

# ========== Vision (image / sticker understanding) ==========
# Leave blank to skip vision and fall back to NapCat OCR only.
# Model name starting with "glm-" -> Zhipu OpenAI-compatible endpoint (GLM_API_KEY + GLM_BASE_URL).
# Model name starting with "claude-" -> uses ANTHROPIC_BASE_URL.
VISION_MODEL=
GLM_API_KEY=
GLM_BASE_URL=

# ========== Owner (the "closest" person to the bot; used in prompts, optional) ==========
OWNER_QQ=
OWNER_NAME=
# Relationship label, e.g. brother / boss / friend / owner. Leave blank to skip in prompts.
OWNER_RELATIONSHIP=

# ========== Private chat whitelist ==========
# Comma-separated QQs (in addition to OWNER_QQ) allowed to DM the bot.
# Anyone in this list takes the "ordinary friend" branch in _chat_private
# (looser than group chat, but doesn't get the closer owner-style override).
# Leave blank = only OWNER_QQ may DM the bot.
PRIVATE_ALLOWED_QQS=
