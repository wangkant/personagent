# ========== HTTP service ==========
HOST=0.0.0.0
PORT=8080

# ========== NapCat / OneBot HTTP API ==========
NAPCAT_API=http://127.0.0.1:3000
# 监听的群号（多个用逗号分隔）
QQ_GROUPS=

# ========== Agent — 主模型 (OpenAI-兼容 chat completions) ==========
# 任何 OpenAI-兼容的 endpoint 都行：DeepSeek / 智谱 GLM / 月之暗面 / Together / OpenAI 自己
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# ========== Anthropic 兼容端点（私聊路径用，可与主模型同 provider）==========
# 留空 = 私聊也走主路径
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_PRIVATE_MODEL=

# ========== Bot 身份 ==========
BOT_QQ=
BOT_NAME=
AGENT_ENABLE=true
AGENT_TRIGGER_COUNT=30
AGENT_CONTEXT_LEN=120
AGENT_FOLLOWUP_WINDOW=120
AGENT_MEMORY_FILE=memory.json
AGENT_MEMORY_MAX=50

# 人设：复制 persona.example.txt 到 persona.txt 后改成你想要的样子
# PERSONA_FILE=persona.txt

# ========== 频率降级（高频时短暂降级到便宜模型）==========
FALLBACK_MODEL=
RATE_WINDOW=120
RATE_THRESHOLD=30
FALLBACK_DURATION=180

# ========== 自评估（每次回复后异步打分到 eval.jsonl）==========
EVAL_ENABLE=true
EVAL_MODEL=
EVAL_FILE=eval.jsonl

# ========== Vision（图片理解 / 表情包打 tag）==========
# 留空 = 跳过 vision，只走 NapCat OCR
# 模型名以 glm- 开头 → 智谱 OpenAI-兼容 endpoint（GLM_API_KEY + GLM_BASE_URL）
# 模型名以 claude- 开头 → 走 ANTHROPIC_BASE_URL
VISION_MODEL=
GLM_API_KEY=
GLM_BASE_URL=

# ========== Owner（bot 最熟的人，给 prompt 用，可留空）==========
OWNER_QQ=
OWNER_NAME=
# 关系标签，例 哥/姐/老板/主人；留空则 prompt 里不强调关系
OWNER_RELATIONSHIP=
