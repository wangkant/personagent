# ============================================================================
# REQUIRED — fill these in to get a first reply
# ============================================================================

# Primary chat model. ANY OpenAI-compatible endpoint works:
# DeepSeek / Zhipu GLM / Moonshot / Together / OpenAI / a local ollama or
# llama.cpp server. This single key is all `python try_chat.py` needs.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# The bot's display name (used in prompts).
BOT_NAME=

# ============================================================================
# REQUIRED FOR A LIVE QQ / OneBot DEPLOYMENT (not needed for `python try_chat.py`)
# ============================================================================

# The bot account's QQ number, and the group(s) to listen on (comma-separated).
# Leave QQ_GROUPS empty to listen in every group.
BOT_QQ=
QQ_GROUPS=

# Where the agent reaches your OneBot client's HTTP API to SEND replies
# (NapCat's HTTP server). The client posts events the other way, to PORT below.
NAPCAT_API=http://127.0.0.1:3000

# ============================================================================
# AGENT
# ============================================================================

# Language of the agent: en (default, primary build) or zh (Chinese variant).
# Selects the per-language data files (persona / examples / feedback /
# output_filter / lorebook -> *.en.* vs *.zh.*), the reply validator mode,
# and the control-flow lexicons.
AGENT_LANG=en

# HTTP service the OneBot client posts webhooks to.
HOST=0.0.0.0
PORT=8080

AGENT_ENABLE=true
AGENT_TRIGGER_COUNT=30
AGENT_CONTEXT_LEN=120
AGENT_FOLLOWUP_WINDOW=120
AGENT_MEMORY_FILE=memory.json
AGENT_MEMORY_MAX=50

# Persona: copy data/persona.example.en.txt (or .zh.txt) to persona.txt and edit it.
# Until you do, the agent falls back to the bundled example for AGENT_LANG.
# PERSONA_FILE=persona.txt

# ============================================================================
# OPTIONAL — safe to leave blank for a first run
# ============================================================================

# --- Anthropic-compatible endpoint (used by the MAIN reply path) ---
# Leave ALL THREE blank to route the main reply path through your primary
# endpoint's Anthropic-compatible URL ( {DEEPSEEK_BASE_URL}/anthropic ) using
# DEEPSEEK_API_KEY — which is what DeepSeek and most compatible vendors expose.
# Set these only if your primary endpoint has NO Anthropic-compatible path, or
# you want a different model/key for the reply path.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_PRIVATE_MODEL=

# --- Web search (auto fact-lookup for unfamiliar things) ---
# With a Tavily key it uses Tavily (more reliable); blank falls back to no-key
# DuckDuckGo (needs the `ddgs` package from requirements.txt).
TAVILY_API_KEY=

# --- Self-eval (async 1-5 scoring of each reply -> eval.jsonl) ---
# Off by default so a first run is cheapest. Turn on once you start tuning.
# Tip: prefer a model from a DIFFERENT vendor than your main chat model —
# same-family self-eval is blind to its own failure modes. If EVAL_MODEL
# contains "moonshot"/"kimi", the call routes through GLM_BASE_URL/GLM_API_KEY.
EVAL_ENABLE=false
EVAL_MODEL=
EVAL_FILE=eval.jsonl

# --- Vision (image / sticker understanding) ---
# Blank = skip vision, OCR-only fallback (costs nothing). A model name starting
# with "glm-" uses GLM_API_KEY/GLM_BASE_URL; "claude-" uses ANTHROPIC_BASE_URL.
VISION_MODEL=
GLM_API_KEY=
GLM_BASE_URL=

# --- Owner (the person the bot is closest to; used in prompts) ---
OWNER_QQ=
OWNER_NAME=
# Relationship label, e.g. brother / boss / friend. Blank = skip in prompts.
OWNER_RELATIONSHIP=

# --- Private chat whitelist ---
# Comma-separated QQs (in addition to OWNER_QQ) allowed to DM the bot. They take
# the "ordinary friend" branch in _chat_private (looser than group, but without
# the closer owner override). Blank = only OWNER_QQ may DM the bot.
PRIVATE_ALLOWED_QQS=

# --- Proactive messaging (the bot occasionally speaks first) ---
# Off by default. When on, a background loop may self-initiate a message after a
# chat has been quiet for a while (outside the sleep window), with cooldowns and
# a low probability — and the model is told to stay quiet unless it genuinely
# has something to say. Works in groups AND DMs; DMs only go to OWNER_QQ +
# PRIVATE_ALLOWED_QQS, and only to people/groups the bot has already seen talk
# this run (it never cold-opens a silent chat).
PROACTIVE_ENABLE=false
PROACTIVE_INTERVAL=1500          # how often the loop checks, seconds (25 min)
PROACTIVE_MIN_SILENCE=2700       # a group must be quiet this long first (45 min)
PROACTIVE_COOLDOWN=10800         # min seconds between group initiations (3h)
PROACTIVE_PROB=0.25              # chance per eligible tick (0-1)
PROACTIVE_DM_MIN_SILENCE=14400   # a DM must be quiet this long first (4h)
PROACTIVE_DM_COOLDOWN=86400      # min seconds between DMs to one person (24h)
PROACTIVE_DM_PROB=0.2            # chance per eligible tick (0-1)

# --- Rate-based fallback (downgrade to a cheaper model when busy) ---
FALLBACK_MODEL=
RATE_WINDOW=120
RATE_THRESHOLD=30
FALLBACK_DURATION=180
