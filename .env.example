# ============================================================================
# REQUIRED — fill these in to get a first reply
# ============================================================================

# Primary chat model. ANY OpenAI-compatible endpoint works:
# DeepSeek / Zhipu GLM / Moonshot / Together / OpenAI / a local ollama or
# llama.cpp server. This single key is all `python try_chat.py` needs.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# The bot's display name (used in prompts).
BOT_NAME=

# ============================================================================
# REQUIRED FOR A LIVE QQ / OneBot DEPLOYMENT (not needed for `python try_chat.py`)
# ============================================================================

# The bot account's QQ number, and the group(s) to listen on (comma-separated).
# Leave QQ_GROUPS empty to listen in every group.
BOT_QQ=
QQ_GROUPS=

# Where the agent reaches your OneBot client's HTTP API to SEND replies
# (NapCat's HTTP server). The client posts events the other way, to PORT below.
NAPCAT_API=http://127.0.0.1:3000

# Optional. If your OneBot client delivers received images as file:// URLs
# (NapCat local-cache mode), set this to that cache directory. When set, the
# agent only reads file:// paths inside it, preventing a crafted image segment
# from making the bot read an arbitrary local file. Leave empty to allow any
# file:// path (default).
NAPCAT_IMAGE_DIR=

# ============================================================================
# AGENT
# ============================================================================

# Language of the agent: en (default, primary build) or zh (Chinese variant).
# Selects the per-language data files (persona / examples / feedback /
# output_filter / lorebook -> *.en.* vs *.zh.*), the reply validator mode,
# and the control-flow lexicons.
AGENT_LANG=en

# HTTP service the OneBot client posts webhooks to.
# Loopback by default: NapCat posts events from the same machine, so the
# webhook never needs to be world-exposed. Set HOST=0.0.0.0 only for a split
# deployment — and then also set WEBHOOK_SECRET, otherwise anyone who can
# reach the port can forge OneBot events (impersonate OWNER_QQ, poison
# memory, burn tokens).
HOST=127.0.0.1
PORT=8080
# Optional OneBot HMAC secret = the `secret` in NapCat's httpClient config.
# When set, every /webhook/qq request body must carry a matching
# `x-signature: sha1=<hex>` header to be accepted.
WEBHOOK_SECRET=

# The persona's timezone as a UTC offset in hours (e.g. 8 = UTC+8, -5 = EST).
# Drives BOTH the time shown to the model in prompts and the 02:00-07:00
# "sleep window" that suppresses spontaneous replies at night. Defaults to 8.
TZ_OFFSET_HOURS=8

AGENT_ENABLE=true
AGENT_TRIGGER_COUNT=30
AGENT_CONTEXT_LEN=120
AGENT_FOLLOWUP_WINDOW=120
AGENT_MEMORY_FILE=memory.json
AGENT_MEMORY_MAX=50

# Persona: copy data/persona.example.en.txt (or .zh.txt) to persona.txt and edit it.
# Until you do, the agent falls back to the bundled example for AGENT_LANG.
# PERSONA_FILE=persona.txt

# ============================================================================
# OPTIONAL — safe to leave blank for a first run
# ============================================================================

# --- Private-chat model (optional) ---
# Alternate model name for 1:1 private chats, served by the SAME primary
# OpenAI-compatible endpoint and key as everything else (the "ANTHROPIC_"
# prefix is historical — no separate endpoint is involved). Blank = use
# DEEPSEEK_MODEL for private chats too.
ANTHROPIC_PRIVATE_MODEL=

# --- Web search (auto fact-lookup for unfamiliar things) ---
# With a Tavily key it uses Tavily (more reliable); blank falls back to no-key
# DuckDuckGo (needs the `ddgs` package from requirements.txt).
TAVILY_API_KEY=

# --- Self-eval (async 1-5 scoring of each reply -> eval.jsonl) ---
# Off by default so a first run is cheapest. Turn on once you start tuning.
# Tip: prefer a model from a DIFFERENT vendor than your main chat model —
# same-family self-eval is blind to its own failure modes. If EVAL_MODEL
# contains "moonshot"/"kimi", the call routes through GLM_BASE_URL/GLM_API_KEY.
EVAL_ENABLE=false
EVAL_MODEL=
EVAL_FILE=eval.jsonl

# --- Vision (image / sticker understanding) ---
# Blank = skip vision, OCR-only fallback (costs nothing). Any OpenAI-compatible
# vision model works; the call always routes through GLM_BASE_URL/GLM_API_KEY.
VISION_MODEL=
GLM_API_KEY=
GLM_BASE_URL=

# --- Owner (the person the bot is closest to; used in prompts) ---
OWNER_QQ=
OWNER_NAME=
# Relationship label, e.g. brother / boss / friend. Blank = skip in prompts.
OWNER_RELATIONSHIP=

# --- Private chat whitelist ---
# Comma-separated QQs (in addition to OWNER_QQ) allowed to DM the bot. They take
# the "ordinary friend" branch in _chat_private (looser than group, but without
# the closer owner override). Blank = only OWNER_QQ may DM the bot.
PRIVATE_ALLOWED_QQS=

# --- Gateway (platform-neutral forwarding, e.g. an AstrBot plugin) ---
# POST /webhook/gateway accepts messages forwarded from other platforms
# (Telegram / Discord / Slack / ...) and returns the replies in the HTTP
# response for the forwarder to relay back (see gateway.py for the schema).
# GATEWAY_TOKEN: shared secret the forwarder must send in the X-Gateway-Token
# header; blank = no auth. GATEWAY_OWNER_IDS: comma-separated platform-prefixed
# ids (e.g. telegram:12345) that get the owner branch in gateway DMs.
GATEWAY_TOKEN=
GATEWAY_OWNER_IDS=

# --- Proactive messaging (the bot occasionally speaks first) ---
# Off by default. When on, a background loop may self-initiate a message after a
# chat has been quiet for a while (outside the sleep window), with cooldowns and
# a low probability — and the model is told to stay quiet unless it genuinely
# has something to say. Works in groups AND DMs; DMs only go to OWNER_QQ +
# PRIVATE_ALLOWED_QQS, and only to people/groups the bot has already seen talk
# this run (it never cold-opens a silent chat).
PROACTIVE_ENABLE=false
PROACTIVE_INTERVAL=1500          # how often the loop checks, seconds (25 min)
PROACTIVE_MIN_SILENCE=2700       # a group must be quiet this long first (45 min)
PROACTIVE_COOLDOWN=10800         # min seconds between group initiations (3h)
PROACTIVE_PROB=0.25              # chance per eligible tick (0-1)
PROACTIVE_DM_MIN_SILENCE=14400   # a DM must be quiet this long first (4h)
PROACTIVE_DM_COOLDOWN=86400      # min seconds between DMs to one person (24h)
PROACTIVE_DM_PROB=0.2            # chance per eligible tick (0-1)

# --- Reaction learning (learn from real user reactions — primary signal) ---
# On by default. Every sent reply briefly waits for a DIRECTED user reaction:
# a quote of the bot's message, an @/name-call, or (in a DM) the other
# person's next message. An in-process adjudicator (one cheap LLM call)
# classifies it — correction / rejection / positive / neutral — filters
# banter and trolling (the owner's corrections carry the most weight), and
# only then learns: corrections become BAD -> OK feedback pairs, genuine
# positive reactions bank the reply into the example pool. Everything is
# audited in candidates.jsonl (src=user_reaction).
REACT_LEARN=true
REACT_TTL_SEC=900         # how long a reply waits for a reaction (15 min)
REACT_MAX_PENDING=4       # replies tracked per conversation
REACT_MODEL=              # blank = JUDGE_MODEL (cheapest configured)

# --- Self-evolution (unattended eval -> feedback learning loop) ---
# Off by default. When on, a background loop periodically takes new low-score
# entries from eval.jsonl, has a model diagnose the failure and draft a
# BAD -> OK rewrite, and appends the pair to data/feedback.<lang>.jsonl — which
# hot-reloads into few-shot retrieval, so the bot learns from its own misses
# while running. Same pipeline with a human approval gate instead:
#   python tools/auto_reviewer.py --apply
# Needs EVAL_ENABLE=true (without scores there is nothing to learn from).
EVOLVE_AUTO=false
EVOLVE_INTERVAL_HOURS=6   # how often to look for new low-score entries
EVOLVE_THRESHOLD=2        # score <= this counts as a miss (keep strict: unattended)
EVOLVE_BATCH=5            # max entries diagnosed per tick
EVOLVE_MODEL=             # blank = EVAL_MODEL (falls back to the chat model)

# --- Rate-based fallback (downgrade to a cheaper model when busy) ---
FALLBACK_MODEL=
RATE_WINDOW=120
RATE_THRESHOLD=30
FALLBACK_DURATION=180

# --- Two-stage routing: cheap gate, main-model reply ---
# Self-initiated modes (judge / followup / proactive) first ask this cheapest
# model only "would a real person reply here, or stay quiet?". If it decides to
# reply, the line that's actually sent is (re)written by the main model — so the
# group never sees output from the cheap model. Blank = use FALLBACK_MODEL (or
# the main model). Point it at the cheapest model you have.
JUDGE_MODEL=
